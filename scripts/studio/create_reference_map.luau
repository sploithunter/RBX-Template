--[[
    Creates a tiny authored reference map in Workspace.

    Run from Roblox Studio command bar or through Studio MCP while NOT in play
    mode. The generated map is intentionally simple: two floors, invisible-ish
    gameplay markers, and visible travel fixtures. Rojo does not own this
    Workspace subtree, so Studio can save/edit it.
]]

local CollectionService = game:GetService("CollectionService")

local ROOT_NAME = "AuthoredReferenceMap"

local function addTag(instance, tag)
    if not CollectionService:HasTag(instance, tag) then
        CollectionService:AddTag(instance, tag)
    end
end

local function ensureFolder(parent, name)
    local folder = parent:FindFirstChild(name)
    if not folder or not folder:IsA("Folder") then
        if folder then
            folder:Destroy()
        end
        folder = Instance.new("Folder")
        folder.Name = name
        folder.Parent = parent
    end
    return folder
end

local function makePart(parent, name, size, position, options)
    options = options or {}

    local part = Instance.new(options.className or "Part")
    part.Name = name
    part.Anchored = true
    part.CanCollide = options.canCollide == true
    part.CanTouch = options.canTouch ~= false
    part.CanQuery = options.canQuery ~= false
    part.Transparency = options.transparency or 0
    part.Size = size
    part.Position = position
    part.Color = options.color or Color3.fromRGB(255, 255, 255)
    part.Material = options.material or Enum.Material.SmoothPlastic
    part.Parent = parent
    return part
end

local existing = workspace:FindFirstChild(ROOT_NAME)
if existing then
    if existing:GetAttribute("GeneratedByReferenceMapScript") ~= true then
        error(ROOT_NAME .. " exists but was not generated by this script; refusing to overwrite")
    end
    existing:Destroy()
end

local root = Instance.new("Folder")
root.Name = ROOT_NAME
root:SetAttribute("GeneratedByReferenceMapScript", true)
root.Parent = workspace

local geometry = ensureFolder(root, "Geometry")
local markers = ensureFolder(root, "Markers")
local travel = ensureFolder(root, "Travel")
local anchors = ensureFolder(root, "Anchors")

local areas = {
    Spawn = {
        center = Vector3.new(0, 0, 0),
        parentZoneId = "spawn_island",
        floorColor = Color3.fromRGB(52, 163, 82),
    },
    Meadow = {
        center = Vector3.new(220, 0, 0),
        parentZoneId = "meadow_island",
        floorColor = Color3.fromRGB(72, 186, 102),
    },
}

for areaId, area in pairs(areas) do
    makePart(
        geometry,
        "Floor_" .. areaId,
        Vector3.new(160, 4, 160),
        area.center + Vector3.new(0, -2, 0),
        {
            canCollide = true,
            canTouch = true,
            color = area.floorColor,
            material = Enum.Material.Grass,
        }
    )

    local areaZone = makePart(
        markers,
        "AreaZone_" .. areaId,
        Vector3.new(160, 18, 160),
        area.center + Vector3.new(0, 7, 0),
        {
            canTouch = true,
            canQuery = true,
            transparency = 0.9,
            color = Color3.fromRGB(90, 180, 255),
            material = Enum.Material.ForceField,
        }
    )
    areaZone:SetAttribute("ZoneId", areaId)
    areaZone:SetAttribute("Kind", "area")
    areaZone:SetAttribute("ParentZoneId", area.parentZoneId)
    areaZone:SetAttribute("AreaId", areaId)
    addTag(areaZone, "Zone")
    addTag(areaZone, "AreaZone")
end

local zoneMarkers = {
    {
        id = "spawn_world",
        kind = "world",
        parent = nil,
        primaryArea = "Spawn",
        center = Vector3.new(110, 20, 0),
        size = Vector3.new(420, 40, 220),
    },
    {
        id = "spawn_island",
        kind = "island",
        parent = "spawn_world",
        primaryArea = "Spawn",
        center = Vector3.new(0, 16, 0),
        size = Vector3.new(180, 32, 180),
    },
    {
        id = "meadow_island",
        kind = "island",
        parent = "spawn_world",
        primaryArea = "Meadow",
        center = Vector3.new(220, 16, 0),
        size = Vector3.new(180, 32, 180),
    },
}

for _, zone in ipairs(zoneMarkers) do
    local part = makePart(markers, "Zone_" .. zone.id, zone.size, zone.center, {
        canTouch = true,
        canQuery = true,
        transparency = 1,
        color = Color3.fromRGB(255, 255, 255),
    })
    part:SetAttribute("ZoneId", zone.id)
    part:SetAttribute("Kind", zone.kind)
    if zone.parent then
        part:SetAttribute("ParentZoneId", zone.parent)
    end
    addTag(part, "Zone")
end

local gameFolder = ensureFolder(workspace, "Game")
local breakablesFolder = ensureFolder(gameFolder, "Breakables")
local crystalsFolder = ensureFolder(breakablesFolder, "Crystals")

for areaId, area in pairs(areas) do
    local worldFolder = ensureFolder(crystalsFolder, areaId)
    ensureFolder(worldFolder, "Items")

    local current = Instance.new("NumberValue")
    current.Name = "CurrentItems"
    current.Value = 0
    current.Parent = worldFolder

    local max = Instance.new("NumberValue")
    max.Name = "Max"
    max.Value = areaId == "Spawn" and 14 or 8
    max.Parent = worldFolder

    local spawnArea = makePart(
        worldFolder,
        "SpawnArea",
        Vector3.new(areaId == "Spawn" and 140 or 130, 1, areaId == "Spawn" and 140 or 130),
        area.center,
        {
            canTouch = true,
            canQuery = true,
            transparency = 0.92,
            color = Color3.fromRGB(255, 215, 80),
            material = Enum.Material.ForceField,
        }
    )
    spawnArea:SetAttribute("AreaId", areaId)
    spawnArea:SetAttribute("SpawnerId", "spawn_crystals")
    spawnArea:SetAttribute("DepthOffset", 0)
    spawnArea:SetAttribute("MaxCountOverride", max.Value)
    addTag(spawnArea, "SpawnZone")
end

local eggsFolder = ensureFolder(gameFolder, "Eggs")
local spawnPoints = ensureFolder(eggsFolder, "SpawnPoints")
local eggStands = {
    {
        eggId = "basic_egg",
        spawnId = "BasicEarth",
        position = Vector3.new(0, 0.5, -22),
    },
}

for _, stand in ipairs(eggStands) do
    local eggStand = makePart(spawnPoints, "EggSpawnPoint", Vector3.new(3, 1, 3), stand.position, {
        canTouch = false,
        canQuery = false,
        transparency = 0.9,
        color = Color3.fromRGB(255, 255, 255),
    })
    eggStand:SetAttribute("AreaId", "Spawn")
    eggStand:SetAttribute("EggId", stand.eggId)
    eggStand:SetAttribute("EggType", stand.eggId)
    eggStand:SetAttribute("SpawnId", stand.spawnId)
    addTag(eggStand, "EggStand")
end

local function makePad(sourceAreaId, targetZoneId, offset)
    local source = areas[sourceAreaId]
    local pad = makePart(
        travel,
        "TeleportPad_" .. sourceAreaId .. "_to_" .. targetZoneId,
        Vector3.new(12, 1, 12),
        source.center + offset,
        {
            canTouch = true,
            canQuery = true,
            transparency = 0.25,
            color = Color3.fromRGB(80, 220, 255),
            material = Enum.Material.Neon,
        }
    )
    pad:SetAttribute("AreaId", sourceAreaId)
    pad:SetAttribute("TargetZoneId", targetZoneId)
    addTag(pad, "TeleportPad")
end

makePad("Spawn", "Meadow", Vector3.new(52, 0.5, 0))
makePad("Meadow", "Spawn", Vector3.new(-52, 0.5, 0))

local function makePortal(sourceZoneId, targetZoneId, sourceAreaId, offset)
    local source = areas[sourceAreaId]
    local portal = makePart(
        travel,
        "Portal_" .. sourceZoneId .. "_to_" .. targetZoneId,
        Vector3.new(10, 16, 2),
        source.center + offset,
        {
            canTouch = true,
            canQuery = true,
            transparency = 0.2,
            color = Color3.fromRGB(180, 90, 255),
            material = Enum.Material.Neon,
        }
    )
    portal:SetAttribute("ZoneId", sourceZoneId)
    portal:SetAttribute("TargetZoneId", targetZoneId)
    addTag(portal, "Portal")
end

makePortal("spawn_island", "meadow_island", "Spawn", Vector3.new(0, 8, 52))
makePortal("meadow_island", "spawn_island", "Meadow", Vector3.new(0, 8, -52))

for areaId, area in pairs(areas) do
    local podium = makePart(
        anchors,
        areaId == "Spawn" and "PetDisplay_Podium" or ("PetDisplay_Podium_" .. areaId),
        Vector3.new(6, 1, 6),
        area.center + Vector3.new(0, 0.5, 34),
        {
            canTouch = false,
            canQuery = true,
            transparency = 0.55,
            color = Color3.fromRGB(255, 255, 255),
            material = Enum.Material.Glass,
        }
    )
    podium:SetAttribute("AreaId", areaId)
    podium:SetAttribute("Slot", 1)
    addTag(podium, "PODPodium")
end

return "Created AuthoredReferenceMap with Spawn/Meadow markers. Save the place in Studio to keep it."
