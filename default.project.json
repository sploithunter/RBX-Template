{
  "name": "game-template",
  "servePort": 34872,
  "globIgnorePaths": [
    "Packages/**/*.project.json"
  ],
  "tree": {
    "$className": "DataModel",
    "Workspace": {
      "$ignoreUnknownInstances": true
    },
    "ServerScriptService": {
      "Server": {
        "$path": "src/Server"
      }
    },
    "ReplicatedStorage": {
      "Assets": {
        "$className": "Folder"
      },
      "Shared": {
        "$path": "src/Shared"
      },
      "Packages": {
        "$path": "Packages"
      },
      "Tests": {
        "$path": "tests"
      },
      "Configs": {
        "$path": "configs"
      }
    },
    "StarterPlayer": {
      "StarterPlayerScripts": {
        "Client": {
          "$path": "src/Client"
        }
      }
    }
  }
} 
